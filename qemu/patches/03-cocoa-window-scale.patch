+    /* Optional initial window magnification for zoom-to-fit (QEMU_COCOA_SCALE). */
+    {
+        const char *scale_env = getenv("QEMU_COCOA_SCALE");
+        if (scale_env && scale_env[0]) {
+            double v = atof(scale_env);
+            if (v >= 1.0 && v <= 8.0) {
+                cocoa_zoom_scale = v;
+                /* Smooth the upscale so 2x doesn't look blocky. */
+                if (v != 1.0 && zoom_interpolation == kCGInterpolationNone) {
+                    zoom_interpolation = kCGInterpolationLow;
+                }
+            }
+        }
