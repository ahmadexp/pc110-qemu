@@ -635,6 +643,20 @@
     } else if ([[self window] styleMask] & NSWindowStyleMaskFullScreen) {
         [[self window] setContentSize:[self fixAspectRatio:[self screenSafeAreaSize]]];
         [[self window] center];
+    } else if (cocoa_zoom_scale != 1.0 && screen.width > 0 && screen.height > 0) {
+        /*
+         * Zoom-to-fit with an explicit magnification (QEMU_COCOA_SCALE): size the
+         * window deterministically to the guest resolution scaled by the factor,
+         * converting guest pixels to points via the backing scale so the physical
+         * size is consistent on Retina and non-Retina displays.
+         */
+        CGFloat bs = [[self window] backingScaleFactor];
+        if (bs < 1.0) {
+            bs = 1.0;
+        }
+        NSSize target = NSMakeSize(screen.width * cocoa_zoom_scale / bs,
+                                   screen.height * cocoa_zoom_scale / bs);
+        [[self window] setContentSize:[self fixAspectRatio:target]];
     } else {
         [[self window] setContentSize:[self fixAspectRatio:[self frame].size]];
     }
