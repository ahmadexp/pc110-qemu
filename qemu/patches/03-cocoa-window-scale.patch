 static CGInterpolationQuality zoom_interpolation = kCGInterpolationNone;
+/*
+ * Initial window magnification for the zoom-to-fit (resizable) path.  1.0 keeps
+ * QEMU's default (window opens at the guest's pixel size in points, which on a
+ * high-DPI/Retina Mac is physically tiny).  Set QEMU_COCOA_SCALE=2 to open the
+ * window twice as large; the guest framebuffer is scaled to fill it.  The window
+ * stays freely resizable afterwards.
+ */
+static double cocoa_zoom_scale = 1.0;
