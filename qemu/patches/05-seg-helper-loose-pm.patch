+/*
+ * PC110 "loose protected mode" scaffold (enabled by the PC110POST env var).
+ *
+ * The genuine IBM PC110 BIOS + RIOS driver stack runs stretches of code in an
+ * "unreal mode" state: it sets CR0.PE=1 with LMSW but keeps loading real-mode
+ * style segment values (e.g. F000) into segment registers, and takes interrupts
+ * / IRETs while in that state.  On a faithful x86 (QEMU) every such segment
+ * operation #GPs because those selectors have no valid GDT descriptor, which
+ * produces an endless general-protection fault storm.  The reference emulator
+ * PC110-EMU boots this same BIOS to the desktop precisely because its segment
+ * resolver (pc110_segment_base_for_selector) FALLS BACK to selector<<4 (with a
+ * couple of hardcoded PC110 bases) whenever the GDT descriptor is absent.
+ *
+ * pc110_synth_desc() reproduces that: when the requested selector has no valid
+ * descriptor, synthesise a present 16-bit segment descriptor whose base is
+ * selector<<4 (0x40->0xF0000, 0x38/0x48->0), so the load succeeds like it does
+ * on the reference instead of faulting.
+ */
+extern int pc110_booted; /* set by target/i386/pc110post.c once DOS has booted */
+
+static int pc110_loose_pm(void)
+{
+    static int en = -1;
+    if (en < 0) {
+        en = getenv("PC110POST") ? 1 : 0;
+    }
+    /* Only loosen PM AFTER DOS has booted: pre-boot POST runs correctly under
+     * faithful protected mode; the loose scaffold is only needed for the
+     * driver's post-boot unreal-mode segment usage. */
+    return en && pc110_booted;
+}
+
+static uint32_t pc110_loose_base(unsigned selector)
+{
+    selector &= 0xffff;
+    if (selector == 0x0040) {
+        return 0x000F0000;
+    }
+    if (selector == 0x0038 || selector == 0x0048) {
+        return 0x00000000;
+    }
+    return (uint32_t)selector << 4;
+}
+
+/*
+ * Resolve a selector's base exactly like PC110-EMU's
+ * pc110_segment_base_for_selector: use the GDT/LDT descriptor's base ONLY when
+ * the descriptor's access byte (bits 15:8 of e2) is non-zero; otherwise (empty
+ * or absent descriptor) fall back to selector<<4.  Loading an empty descriptor's
+ * stale base is what sent CS=0x70 to 0xA0000 (VGA memory) -> #UD.
+ */
+static inline uint32_t get_seg_base(uint32_t e1, uint32_t e2);
+
+static inline uint32_t get_seg_limit(uint32_t e1, uint32_t e2);
+
+static uint32_t pc110_resolve_base(CPUX86State *env, unsigned selector)
+{
+    unsigned index = selector & ~7u;
+    SegmentCache *dt = (selector & 4) ? &env->ldt : &env->gdt;
+    if ((selector & 0xfffc) != 0 && (index + 7) <= dt->limit) {
+        uint32_t e1 = cpu_ldl_kernel_ra(env, dt->base + index, 0);
+        uint32_t e2 = cpu_ldl_kernel_ra(env, dt->base + index + 4, 0);
+        if (((e2 >> 8) & 0xffu) != 0) {
+            return get_seg_base(e1, e2);
+        }
+    }
+    return pc110_loose_base(selector);
+}
+
+/*
+ * Full loose-PM segment resolution.  For a selector with a valid (access!=0)
+ * in-limit descriptor, return its REAL base/limit/flags -- crucially preserving
+ * 32-bit-ness (DESC_B/DESC_G), because EMM386's own code/data segments are
+ * 32-bit and running them as forced-16-bit misdecodes instructions and derails
+ * control flow.  Only for empty/out-of-limit selectors do we synthesise a
+ * real-mode-style 16-bit segment based at selector<<4.
+ */
+static void pc110_resolve_seg(CPUX86State *env, unsigned selector, int is_code,
+                              uint32_t *base, uint32_t *limit, uint32_t *flags)
+{
+    unsigned index = selector & ~7u;
+    SegmentCache *dt = (selector & 4) ? &env->ldt : &env->gdt;
+    if ((selector & 0xfffc) != 0 && (index + 7) <= dt->limit) {
+        uint32_t e1 = cpu_ldl_kernel_ra(env, dt->base + index, 0);
+        uint32_t e2 = cpu_ldl_kernel_ra(env, dt->base + index + 4, 0);
+        if (((e2 >> 8) & 0xffu) != 0) {
+            *base = get_seg_base(e1, e2);
+            *limit = get_seg_limit(e1, e2);
+            *flags = e2 | DESC_P_MASK;
+            return;
+        }
+    }
+    *base = pc110_loose_base(selector);
+    *limit = 0xffff;
+    *flags = DESC_P_MASK | DESC_S_MASK | DESC_A_MASK |
+             (is_code ? (DESC_CS_MASK | DESC_R_MASK) : DESC_W_MASK);
+}
+
+/* Diagnostic: flag any loose far transfer that lands CS in the VGA aperture
+ * (0xA0000-0xBFFFF) -- executing there means a bad control transfer. */
+static void pc110_dbg_cs(CPUX86State *env, const char *tag, unsigned sel,
+                         uint32_t base, uint32_t neweip)
+{
+    if (base >= 0x000A0000 && base < 0x000C0000 && getenv("PC110RSTLOG")) {
+        static int n;
+        if (n++ < 24) {
+            fprintf(stderr, "[pc110loose] %s CS<=%04x base=%05X eip=%04X  "
+                    "from %04x:%08x SP=%04x:%08x\n", tag, sel, (unsigned)base,
+                    (unsigned)neweip, env->segs[R_CS].selector,
+                    (unsigned)env->eip, env->segs[R_SS].selector,
+                    (unsigned)env->regs[R_ESP]);
+        }
+    }
+}
+
+/* Synthesise e1/e2 for a real-mode-style (unreal) selector; returns true when
+ * the loose-PM scaffold is active. */
+static bool pc110_synth_desc(unsigned selector, int is_code,
+                             uint32_t *e1, uint32_t *e2)
+{
+    uint32_t base;
+    if (!pc110_loose_pm()) {
+        return false;
+    }
+    base = pc110_loose_base(selector);
+    *e1 = ((base & 0xffffu) << 16) | 0xffffu;                 /* base[15:0], limit */
+    *e2 = ((base >> 16) & 0xffu) | (base & 0xff000000u)       /* base[23:16],[31:24] */
+        | DESC_P_MASK | DESC_S_MASK | DESC_A_MASK
+        | (((uint32_t)selector & 3u) << DESC_DPL_SHIFT)
+        | (is_code ? (DESC_CS_MASK | DESC_R_MASK) : DESC_W_MASK);
+    return true;
+}
